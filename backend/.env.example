# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL="postgresql://simpaskor_user:simpaskor_password@localhost:5432/simpaskor_db"

# Alternative individual database settings (if not using DATABASE_URL)
# DB_HOST="localhost"
# DB_PORT="5432"
# DB_USER="simpaskor_user"
# DB_PASSWORD="simpaskor_password"
# DB_NAME="simpaskor_db"

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Secret - MUST be at least 32 characters long for security
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long-please"

# JWT Token Expiration (optional, defaults to 24h)
JWT_EXPIRES_IN="24h"

# Bcrypt salt rounds (optional, defaults to 12)
BCRYPT_SALT_ROUNDS=12

# Google reCAPTCHA v3 Secret Key
# Get from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key-here"

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Application environment (development, production, test)
NODE_ENV="development"

# Backend server port
PORT=3001

# Frontend URL for CORS configuration
FRONTEND_URL="http://localhost:5173"

# API base path (optional, defaults to /api)
API_BASE_PATH="/api"

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origins for CORS (comma-separated for multiple)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# CORS credentials (set to true if you need to send cookies)
CORS_CREDENTIALS=true

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level (error, warn, info, debug)
LOG_LEVEL="info"

# Log format (json, simple)
LOG_FORMAT="simple"

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================
# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=100  # max 100 requests per window

# =============================================================================
# DEVELOPMENT ONLY SETTINGS
# =============================================================================
# Enable debug logging in development
DEBUG=true

# Prisma Studio port (optional)
PRISMA_STUDIO_PORT=5555

# Enable SQL query logging
# DATABASE_LOGGING=true

# =============================================================================
# EMAIL CONFIGURATION (for future features)
# =============================================================================
# Email service configuration
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# EMAIL_FROM="noreply@simpaskor.com"

# =============================================================================
# FILE UPLOAD CONFIGURATION (for future features)
# =============================================================================
# Maximum file size for uploads (in bytes)
# MAX_FILE_SIZE=5242880  # 5MB

# Allowed file types for uploads
# ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf"

# Upload directory
# UPLOAD_DIR="uploads"

# =============================================================================
# SESSION CONFIGURATION (if using sessions)
# =============================================================================
# Session secret key
# SESSION_SECRET="your-session-secret-key"

# Session store (memory, redis)
# SESSION_STORE="memory"

# Redis URL (if using Redis for sessions)
# REDIS_URL="redis://localhost:6379"

# =============================================================================
# PRODUCTION ONLY SETTINGS
# =============================================================================
# Production database URL (if different from development)
# PRODUCTION_DATABASE_URL="postgresql://user:pass@prod-host:5432/prod_db"

# SSL configuration for production
# SSL_KEY_PATH="/path/to/ssl/key.pem"
# SSL_CERT_PATH="/path/to/ssl/cert.pem"

# =============================================================================
# THIRD-PARTY INTEGRATIONS (for future features)
# =============================================================================
# AWS S3 Configuration (for file storage)
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="simpaskor-uploads"

# Google OAuth (for social login)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Firebase (for push notifications)
# FIREBASE_PROJECT_ID="your-firebase-project"
# FIREBASE_PRIVATE_KEY="your-firebase-private-key"
# FIREBASE_CLIENT_EMAIL="your-firebase-client-email"

# =============================================================================
# MONITORING & ANALYTICS (for future features)
# =============================================================================
# Sentry DSN (for error tracking)
# SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Google Analytics tracking ID
# GA_TRACKING_ID="UA-XXXXXXXX-X"

# =============================================================================
# CACHE CONFIGURATION (for future features)
# =============================================================================
# Redis cache configuration
# CACHE_REDIS_URL="redis://localhost:6379"
# CACHE_TTL=3600  # Cache TTL in seconds

# =============================================================================
# BACKUP CONFIGURATION (for production)
# =============================================================================
# Database backup configuration
# BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
# BACKUP_RETENTION_DAYS=30
# BACKUP_S3_BUCKET="simpaskor-backups"

# =============================================================================
# IMPORTANT SECURITY NOTES
# =============================================================================
# 1. Never commit this file with real values to version control
# 2. Use strong, unique passwords and secrets
# 3. Rotate secrets regularly in production
# 4. Use environment-specific values for different stages
# 5. Enable SSL/TLS in production
# 6. Regularly update dependencies for security patches
#
# For production deployment:
# - Use a proper secret management service
# - Enable database SSL connections
# - Use secure password policies
# - Implement proper backup strategies
# - Monitor for security vulnerabilities