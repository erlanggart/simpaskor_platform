// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  PANITIA
  JURI
  PESERTA
  PELATIH
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  passwordHash     String     @map("password_hash")
  name             String
  phone            String?
  role             UserRole   @default(PESERTA)
  status           UserStatus @default(PENDING)
  emailVerified    Boolean    @default(false) @map("email_verified")
  isPinned         Boolean    @default(false) @map("is_pinned")
  lastLogin        DateTime?  @map("last_login")
  resetToken       String?    @map("reset_token")
  resetTokenExpiry DateTime?  @map("reset_token_expiry")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  // Relations
  profile            UserProfile?
  sessions           UserSession[]
  createdEvents      Event[]                  @relation("EventCreator")
  participations     EventParticipation[]
  evaluations        Evaluation[]
  materialEvaluations MaterialEvaluation[]
  createdCoupons     EventCoupon[]            @relation("CouponCreator")
  usedCoupons        EventCoupon[]            @relation("CouponUser")
  juryAssignments    JuryEventAssignment[]
  eventComments      EventComment[]
  eventLikes         EventLike[]
  orders             Order[]
  ticketPurchases    TicketPurchase[]

  @@map("users")
}

model UserProfile {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar      String?
  bio         String?
  institution String? // Sekolah/Universitas/Organisasi
  address     String?
  city        String?
  province    String?
  birthDate   DateTime? @map("birth_date")
  gender      String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  deviceName String? @map("device_name")
  lastActive DateTime @default(now()) @map("last_active")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("user_sessions")
}

// Many-to-many relationship: Event can be available for multiple school levels

// School Category for Paskibra (SD, SMP, SMA, Purna)
model SchoolCategory {
  id          String   @id @default(uuid())
  name        String   @unique // SD, SMP, SMA, PURNA
  description String?
  order       Int      @default(0) // For sorting
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  participations      EventParticipation[]
  eventLimits         EventSchoolCategoryLimit[]
  groups              ParticipationGroup[]

  @@map("school_categories")
}

// Assessment Category for Paskibra judging (PBB, Komandan, Variasi, etc.)
model AssessmentCategory {
  id          String   @id @default(uuid())
  name        String   @unique // PBB, KOMANDAN, VARIASI, FORMASI, KOSTUM_MAKEUP
  description String?
  order       Int      @default(0) // For sorting display order
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  eventCategories       EventAssessmentCategory[]
  evaluations           Evaluation[]
  juryAssignedCategories JuryAssignedCategory[]

  @@map("assessment_categories")
}

// Many-to-many relationship between Event and AssessmentCategory
model EventAssessmentCategory {
  id                   String             @id @default(uuid())
  eventId              String             @map("event_id")
  event                Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assessmentCategoryId String             @map("assessment_category_id")
  assessmentCategory   AssessmentCategory @relation(fields: [assessmentCategoryId], references: [id], onDelete: Cascade)
  isRequired           Boolean            @default(true) @map("is_required")
  customMaxScore       Int?               @map("custom_max_score") // Override default max score for this event
  customWeight         Decimal?           @map("custom_weight") @db.Decimal(5, 2) // Override default weight
  createdAt            DateTime           @default(now()) @map("created_at")

  @@unique([eventId, assessmentCategoryId])
  @@map("event_assessment_categories")
}

// Event School Category Limit - Defines max participants per school category for each event
model EventSchoolCategoryLimit {
  id                  String         @id @default(uuid())
  eventId             String         @map("event_id")
  event               Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  schoolCategoryId    String         @map("school_category_id")
  schoolCategory      SchoolCategory @relation(fields: [schoolCategoryId], references: [id], onDelete: Cascade)
  maxParticipants     Int            @map("max_participants") // Max participants for this category in this event
  currentParticipants Int            @default(0) @map("current_participants") // Current confirmed participants
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  @@unique([eventId, schoolCategoryId])
  @@map("event_school_category_limits")
}

model Event {
  id                   String       @id @default(uuid())
  title                String // e.g., "Lomba Paskibra Tingkat Nasional 2025"
  slug                 String?      @unique
  description          String? // Event description
  thumbnail            String? // URL/path to event thumbnail image
  juknisUrl            String?      @map("juknis_url") // URL/path to event technical guideline document
  startDate            DateTime     @map("start_date")
  endDate              DateTime     @map("end_date")
  registrationDeadline DateTime?    @map("registration_deadline")
  location             String? // Full location string (deprecated, use province + city)
  province             String? // Province name
  city                 String? // City/Kabupaten name
  venue                String? // Specific venue name
  maxParticipants      Int?         @map("max_participants")
  currentParticipants  Int          @default(0) @map("current_participants")
  registrationFee      Decimal?     @map("registration_fee") @db.Decimal(10, 2)
  organizer            String? // Organization/institution name
  contactPersonName    String?      @map("contact_person_name") // Contact person name
  contactEmail         String?      @map("contact_email")
  contactPhone         String?      @map("contact_phone")
  status               String       @default("DRAFT") // DRAFT, PUBLISHED, ONGOING, COMPLETED, CANCELLED
  wizardStep           Int          @default(1) @map("wizard_step") // Current wizard step (1-3), 0 = completed
  wizardCompleted      Boolean      @default(false) @map("wizard_completed") // Whether wizard is completed
  featured             Boolean      @default(false) // Featured events appear on landing page
  isPinned             Boolean      @default(false) @map("is_pinned") // Pinned events appear in carousel
  pinnedOrder          Int?         @map("pinned_order") // Display order in carousel (lower = first)
  couponId             String?      @map("coupon_id") // Coupon used to create this event (legacy)
  coupon               EventCoupon? @relation(fields: [couponId], references: [id])
  packageTier          PackageTier? @map("package_tier") // Selected package tier for event creation
  paymentStatus        String?      @map("payment_status") // PENDING, PAID - tracks if event creation payment is done
  createdById          String       @map("created_by_id")
  createdBy            User         @relation("EventCreator", fields: [createdById], references: [id])
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  // Relations
  participations       EventParticipation[]
  evaluations          Evaluation[]
  materialEvaluations  MaterialEvaluation[]
  assessmentCategories EventAssessmentCategory[]
  schoolCategoryLimits EventSchoolCategoryLimit[]
  juryAssignments      JuryEventAssignment[]
  materials            EventMaterial[]
  comments             EventComment[]
  likes                EventLike[]
  ticketConfig         EventTicketConfig?
  ticketPurchases      TicketPurchase[]
  votingConfig         EventVotingConfig?
  votingPurchases      VotingPurchase[]
  eventPayment         EventPayment?

  @@map("events")
}

// Jury Event Assignment - Tracks which jury is assigned to which event
model JuryEventAssignment {
  id                    String                           @id @default(uuid())
  juryId                String                           @map("jury_id")
  jury                  User                             @relation(fields: [juryId], references: [id], onDelete: Cascade)
  eventId               String                           @map("event_id")
  event                 Event                            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status                String                           @default("PENDING") // PENDING, CONFIRMED, REJECTED
  invitedAt             DateTime                         @default(now()) @map("invited_at")
  respondedAt           DateTime?                        @map("responded_at")
  rejectionReason       String?                          @map("rejection_reason")
  notes                 String? // Notes from panitia to jury
  createdAt             DateTime                         @default(now()) @map("created_at")
  updatedAt             DateTime                         @updatedAt @map("updated_at")

  // Relations
  assignedCategories    JuryAssignedCategory[]

  @@unique([juryId, eventId])
  @@index([juryId, status])
  @@map("jury_event_assignments")
}

// Junction table for Jury assigned assessment categories
model JuryAssignedCategory {
  id                   String                @id @default(uuid())
  assignmentId         String                @map("assignment_id")
  assignment           JuryEventAssignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assessmentCategoryId String                @map("assessment_category_id")
  assessmentCategory   AssessmentCategory    @relation(fields: [assessmentCategoryId], references: [id], onDelete: Cascade)
  createdAt            DateTime              @default(now()) @map("created_at")

  @@unique([assignmentId, assessmentCategoryId])
  @@map("jury_assigned_categories")
}

model EventCoupon {
  id               String    @id @default(uuid())
  code             String    @unique // Unique coupon code (e.g., "EVENT2025-ABC123")
  description      String? // Description/notes about this coupon
  assignedToEmail  String?   @map("assigned_to_email") // Email of Panitia this coupon is assigned to
  expiresAt        DateTime? @map("expires_at") // Expiration date - events using expired coupons cannot be edited
  isUsed           Boolean   @default(false) @map("is_used")
  usedById         String?   @map("used_by_id")
  usedBy           User?     @relation("CouponUser", fields: [usedById], references: [id])
  usedAt           DateTime? @map("used_at")
  createdByAdminId String    @map("created_by_admin_id")
  createdByAdmin   User      @relation("CouponCreator", fields: [createdByAdminId], references: [id])
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  events Event[]

  @@map("event_coupons")
}

model EventParticipation {
  id               String          @id @default(uuid())
  eventId          String          @map("event_id")
  event            Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId           String          @map("user_id")
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolCategoryId String?         @map("school_category_id") // Optional - for backward compatibility
  schoolCategory   SchoolCategory? @relation(fields: [schoolCategoryId], references: [id])
  teamName         String?         @map("team_name") // Name of the Paskibra team
  schoolName       String?         @map("school_name") // Name of the school
  supportingDoc    String?         @map("supporting_doc") // URL to supporting document
  status           String          @default("REGISTERED") // REGISTERED, CONFIRMED, ATTENDED, CANCELLED
  totalScore       Float?          @map("total_score") // Calculated from all evaluations
  rank             Int?
  notes            String?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  // Relations
  groups              ParticipationGroup[]
  registrationPayment RegistrationPayment?

  @@unique([eventId, userId])
  @@map("event_participations")
}

// Participation Group - Each group represents one team registration
model ParticipationGroup {
  id               String             @id @default(uuid())
  participationId  String             @map("participation_id")
  participation    EventParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  schoolCategoryId String             @map("school_category_id")
  schoolCategory   SchoolCategory     @relation(fields: [schoolCategoryId], references: [id])
  groupName        String             @map("group_name") // e.g., "Tim A", "Tim B"
  teamMembers      Int                @default(1) @map("team_members") // Number of members in this group
  memberNames      String?            @map("member_names") // JSON array of member names
  memberData       String?            @map("member_data") // JSON array of member details with photos
  orderNumber      Int?               @map("order_number") // Order number for confirmed participants (per event & school category)
  status           String             @default("ACTIVE") // ACTIVE, CANCELLED
  notes            String?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@map("participation_groups")
}

model Evaluation {
  id                   String             @id @default(uuid())
  eventId              String             @map("event_id")
  event                Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assessmentCategoryId String             @map("assessment_category_id")
  assessmentCategory   AssessmentCategory @relation(fields: [assessmentCategoryId], references: [id])
  juryId               String             @map("jury_id")
  jury                 User               @relation(fields: [juryId], references: [id])
  participantId        String             @map("participant_id")
  score                Float // Score given for this specific assessment category
  maxScore             Int                @default(100) @map("max_score") // Max score for this evaluation
  notes                String?
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@unique([eventId, assessmentCategoryId, juryId, participantId])
  @@map("evaluations")
}

// Event Material - Materi per kategori penilaian per event
model EventMaterial {
  id                        String   @id @default(uuid())
  eventId                   String   @map("event_id")
  event                     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventAssessmentCategoryId String   @map("event_assessment_category_id")
  number                    Int      // Nomor urut materi (1, 2, 3, ...)
  name                      String   // Nama materi (e.g., "Maju Langkah", "Hadap Kanan")
  description               String?  // Deskripsi materi
  order                     Int      @default(0) // Urutan tampilan
  
  // Denormalized for performance - stores JSON array of score categories with options
  // Format: [{"name": "Kurang", "color": "red", "order": 0, "options": [{"name": "", "score": 1, "order": 0}]}]
  scoreCategories           Json     @default("[]") @map("score_categories")
  
  // Denormalized for performance - stores array of school category UUIDs
  schoolCategoryIds         String[] @default([]) @map("school_category_ids")
  
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@unique([eventId, eventAssessmentCategoryId, number])
  @@map("event_materials")
}

// Material Evaluation - Penilaian per materi oleh juri
model MaterialEvaluation {
  id                String   @id @default(uuid())
  eventId           String   @map("event_id")
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  materialId        String   @map("material_id")
  juryId            String   @map("jury_id")
  jury              User     @relation(fields: [juryId], references: [id])
  participantId     String   @map("participant_id") // ParticipationGroup ID
  
  // Score - null means "not scored" and requires skipReason
  score             Float?   // Score given for this material
  scoreCategoryName String?  @map("score_category_name") // e.g., "Kurang", "Cukup", "Baik"
  
  // Skip reason if not scoring (materi tidak sesuai, materi tidak dijalankan)
  isSkipped         Boolean  @default(false) @map("is_skipped")
  skipReason        String?  @map("skip_reason") // "TIDAK_SESUAI" or "TIDAK_DIJALANKAN"
  
  notes             String?
  scoredAt          DateTime? @map("scored_at") // Client-side timestamp when jury clicked score
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([eventId, materialId, juryId, participantId])
  @@map("material_evaluations")
}

// Extra Nilai - Punishment (pengurangan) atau Poin Plus (penambahan) untuk peserta
enum ExtraNilaiType {
  PUNISHMENT  // Pengurangan nilai
  POINPLUS    // Penambahan nilai
}

enum ExtraNilaiScope {
  GENERAL   // Diterapkan ke total nilai keseluruhan
  CATEGORY  // Diterapkan ke kategori penilaian tertentu
  JUARA     // Diterapkan ke total juara tertentu (Juara Utama / Juara Umum / Custom)
}

model ExtraNilai {
  id                   String              @id @default(uuid())
  eventId              String              @map("event_id")
  participantId        String              @map("participant_id") // ParticipationGroup ID
  type                 ExtraNilaiType      // PUNISHMENT atau POINPLUS
  scope                ExtraNilaiScope     // GENERAL, CATEGORY, atau JUARA
  assessmentCategoryId String?             @map("assessment_category_id") // Required if scope is CATEGORY
  juaraCategoryId      String?             @map("juara_category_id") // Required if scope is JUARA
  value                Float               // Nilai poin (selalu positif, tipe menentukan + atau -)
  reason               String?             // Alasan pemberian punishment/poin plus
  createdById          String              @map("created_by_id")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  @@index([eventId, participantId])
  @@index([eventId, type])
  @@map("extra_nilai")
}

// Juara Category Type
enum JuaraCategoryType {
  UTAMA   // Juara Utama - primary champion category
  UMUM    // Juara Umum - overall champion (all categories)
  CUSTOM  // Custom category (max 2 per event)
}

// Juara Category - Defines champion calculation categories per event
model JuaraCategory {
  id          String             @id @default(uuid())
  eventId     String             @map("event_id")
  type        JuaraCategoryType
  name        String             // Display name (e.g., "Juara Utama", "Best PBB")
  description String?
  order       Int                @default(0)
  rankCount   Int                @default(3) @map("rank_count") // Number of ranks (e.g., 3 = Juara 1, 2, 3)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  // Relations
  assessmentCategories JuaraCategoryAssessment[]
  ranks                JuaraRank[]

  @@unique([eventId, type, name])
  @@index([eventId])
  @@map("juara_categories")
}

// Juara Rank - Defines rank ranges within a juara category
// Example: Rank 1-3 = "Juara Utama", Rank 4-6 = "Juara Harapan", Rank 7-9 = "Juara Madya"
model JuaraRank {
  id              String        @id @default(uuid())
  juaraCategoryId String        @map("juara_category_id")
  juaraCategory   JuaraCategory @relation(fields: [juaraCategoryId], references: [id], onDelete: Cascade)
  startRank       Int           @map("start_rank")    // Starting rank position (e.g., 1)
  endRank         Int           @map("end_rank")      // Ending rank position (e.g., 3)
  label           String                              // Display label (e.g., "Juara Utama")
  order           Int           @default(0)           // Display order
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@unique([juaraCategoryId, order])
  @@index([juaraCategoryId])
  @@map("juara_ranks")
}

// Junction table - which assessment categories belong to each juara category
model JuaraCategoryAssessment {
  id                   String             @id @default(uuid())
  juaraCategoryId      String             @map("juara_category_id")
  juaraCategory        JuaraCategory      @relation(fields: [juaraCategoryId], references: [id], onDelete: Cascade)
  assessmentCategoryId String             @map("assessment_category_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  @@unique([juaraCategoryId, assessmentCategoryId])
  @@map("juara_category_assessments")
}

// Performance Field - Lapangan atau tempat penampilan peserta
model PerformanceField {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  name        String   // e.g., "Lapangan A", "Lapangan B", "Stage 1"
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  sessions PerformanceSession[]

  @@unique([eventId, name])
  @@index([eventId])
  @@map("performance_fields")
}

// Performance Session - Sesi penampilan peserta di lapangan
model PerformanceSession {
  id            String            @id @default(uuid())
  fieldId       String            @map("field_id")
  field         PerformanceField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  participantId String            @map("participant_id") // ParticipationGroup ID
  startTime     DateTime?         @map("start_time")
  endTime       DateTime?         @map("end_time")
  duration      Int?              // Duration in seconds (calculated from start/end)
  status        String            @default("QUEUED") // QUEUED, PERFORMING, COMPLETED
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  // Relations
  materialChecks MaterialCheck[]

  @@index([fieldId, status])
  @@index([participantId])
  @@map("performance_sessions")
}

// Material Check - Ceklis materi yang dijalankan peserta (tanpa nilai)
model MaterialCheck {
  id         String             @id @default(uuid())
  sessionId  String             @map("session_id")
  session    PerformanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  materialId String             @map("material_id") // EventMaterial ID
  isChecked  Boolean            @default(false) @map("is_checked") // Peserta menjalankan materi ini atau tidak
  notes      String?
  checkedAt  DateTime?          @map("checked_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  @@unique([sessionId, materialId])
  @@map("material_checks")
}

// Event Comment - Komentar publik pada event
model EventComment {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  content   String   // Isi komentar
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@map("event_comments")
}

// Event Like - Like pada event
model EventLike {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId]) // User can only like once per event
  @@index([eventId])
  @@map("event_likes")
}

// ==========================================
// MARKETPLACE
// ==========================================

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

model Product {
  id          String        @id @default(uuid())
  name        String
  description String?
  price       Float
  stock       Int           @default(0)
  thumbnail   String?
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id               String      @id @default(uuid())
  userId           String      @map("user_id")
  totalAmount      Float       @map("total_amount")
  status           OrderStatus @default(PENDING)
  notes            String?
  midtransOrderId  String?     @unique @map("midtrans_order_id")
  snapToken        String?     @map("snap_token")
  paymentType      String?     @map("payment_type")
  paidAt           DateTime?   @map("paid_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  // Relations
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String @map("order_id")
  productId String @map("product_id")
  quantity  Int
  price     Float

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ==========================================
// E-TICKETING
// ==========================================

enum TicketStatus {
  PENDING
  PAID
  USED
  CANCELLED
  EXPIRED
}

model EventTicketConfig {
  id             String   @id @default(uuid())
  eventId        String   @unique @map("event_id")
  enabled        Boolean  @default(false)
  price          Float    @default(0)
  quota          Int      @default(0)
  soldCount      Int      @default(0) @map("sold_count")
  description    String?
  salesStartDate DateTime? @map("sales_start_date")
  salesEndDate   DateTime? @map("sales_end_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_ticket_configs")
}

model TicketPurchase {
  id               String       @id @default(uuid())
  eventId          String       @map("event_id")
  userId           String?      @map("user_id")
  buyerName        String       @map("buyer_name")
  buyerEmail       String       @map("buyer_email")
  buyerPhone       String?      @map("buyer_phone")
  quantity         Int          @default(1)
  totalAmount      Float        @map("total_amount")
  ticketCode       String       @unique @map("ticket_code")
  status           TicketStatus @default(PENDING)
  midtransOrderId  String?      @unique @map("midtrans_order_id")
  snapToken        String?      @map("snap_token")
  paymentType      String?      @map("payment_type")
  paidAt           DateTime?    @map("paid_at")
  usedAt           DateTime?    @map("used_at")
  notes            String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([buyerEmail])
  @@index([ticketCode])
  @@map("ticket_purchases")
}

// ==========================================
// E-VOTING
// ==========================================

enum VotingMode {
  TEAM      // Vote for a team (ParticipationGroup)
  PERSONAL  // Vote for an individual member within a team
}

enum VotingPurchaseStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

// Event-level voting config (enabled, pricing)
model EventVotingConfig {
  id            String    @id @default(uuid())
  eventId       String    @unique @map("event_id")
  enabled       Boolean   @default(false)
  isPaid        Boolean   @default(false) @map("is_paid")
  pricePerVote  Float     @default(0) @map("price_per_vote")
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  event      Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  categories VotingCategory[]

  @@map("event_voting_configs")
}

// Individual voting title/category per event (e.g., "Tim Terfavorit", "Kostum Terindah")
model VotingCategory {
  id                String          @id @default(uuid())
  configId          String          @map("config_id")
  config            EventVotingConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  title             String          // "Tim Terfavorit", "Komandan Terbaik", etc.
  description       String?
  mode              VotingMode      @default(TEAM)
  position          String?         // For PERSONAL mode: position filter (e.g., "Komandan")
  schoolCategoryIds String[]        @default([]) @map("school_category_ids") // Filter by school category UUIDs
  maxVotesPerVoter  Int             @default(1) @map("max_votes_per_voter")
  isActive          Boolean         @default(true) @map("is_active")
  order             Int             @default(0)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  // Relations
  nominees VotingNominee[]
  votes    VotingVote[]

  @@index([configId])
  @@map("voting_categories")
}

// Nominees in a voting category (auto-populated or manually managed)
model VotingNominee {
  id              String         @id @default(uuid())
  categoryId      String         @map("category_id")
  category        VotingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  groupId         String?        @map("group_id") // ParticipationGroup ID (for TEAM mode)
  nomineeName     String         @map("nominee_name") // Display name
  nomineePhoto    String?        @map("nominee_photo")
  nomineeSubtitle String?        @map("nominee_subtitle") // e.g., school name, team name
  voteCount       Int            @default(0) @map("vote_count")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  votes VotingVote[]

  @@index([categoryId])
  @@map("voting_nominees")
}

// Individual vote record
model VotingVote {
  id           String         @id @default(uuid())
  categoryId   String         @map("category_id")
  category     VotingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  nomineeId    String         @map("nominee_id")
  nominee      VotingNominee  @relation(fields: [nomineeId], references: [id], onDelete: Cascade)
  purchaseId   String?        @map("purchase_id") // If paid voting
  purchase     VotingPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  voterName    String?        @map("voter_name")
  voterEmail   String?        @map("voter_email")
  voterIp      String?        @map("voter_ip")
  createdAt    DateTime       @default(now()) @map("created_at")

  @@index([categoryId])
  @@index([nomineeId])
  @@index([voterEmail, categoryId])
  @@map("voting_votes")
}

// Paid voting transaction (like ticket purchase)
model VotingPurchase {
  id               String               @id @default(uuid())
  eventId          String               @map("event_id")
  event            Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  buyerName        String               @map("buyer_name")
  buyerEmail       String               @map("buyer_email")
  buyerPhone       String?              @map("buyer_phone")
  voteCount        Int                  @default(1) @map("vote_count")
  totalAmount      Float                @map("total_amount")
  purchaseCode     String               @unique @map("purchase_code")
  status           VotingPurchaseStatus @default(PENDING)
  midtransOrderId  String?              @unique @map("midtrans_order_id")
  snapToken        String?              @map("snap_token")
  paymentType      String?              @map("payment_type")
  paidAt           DateTime?            @map("paid_at")
  usedVotes        Int                  @default(0) @map("used_votes")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  // Relations
  votes VotingVote[]

  @@index([eventId])
  @@index([buyerEmail])
  @@index([purchaseCode])
  @@map("voting_purchases")
}

// ==========================================
// REGISTRATION PAYMENT (Event Registration Fee)
// ==========================================

enum RegistrationPaymentStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

model RegistrationPayment {
  id                String                    @id @default(uuid())
  participationId   String                    @unique @map("participation_id")
  participation     EventParticipation        @relation(fields: [participationId], references: [id], onDelete: Cascade)
  eventId           String                    @map("event_id")
  userId            String                    @map("user_id")
  amount            Float
  status            RegistrationPaymentStatus @default(PENDING)
  paymentMethod     String?                   @map("payment_method") // MIDTRANS or MANUAL
  midtransOrderId   String?                   @unique @map("midtrans_order_id")
  snapToken         String?                   @map("snap_token")
  paymentType       String?                   @map("payment_type")
  paidAt            DateTime?                 @map("paid_at")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  @@index([participationId])
  @@index([eventId])
  @@index([userId])
  @@map("registration_payments")
}

// ===== Event Payment (Paket Simpaskor untuk buat event) =====

enum EventPaymentStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

model EventPayment {
  id              String             @id @default(uuid())
  eventId         String             @unique @map("event_id")
  event           Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId          String             @map("user_id")
  packageTier     PackageTier        @map("package_tier")
  amount          Float
  status          EventPaymentStatus @default(PENDING)
  midtransOrderId String?            @unique @map("midtrans_order_id")
  snapToken       String?            @map("snap_token")
  paymentType     String?            @map("payment_type")
  paidAt          DateTime?          @map("paid_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([eventId])
  @@index([userId])
  @@map("event_payments")
}

// ===== Guide System =====

enum GuideRole {
  PANITIA
  JURI
  PESERTA
}

model Guide {
  id          String    @id @default(uuid())
  role        GuideRole
  title       String
  description String?
  icon        String?   // icon name e.g. "LuCalendarPlus"
  order       Int       @default(0)
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  slides      GuideSlide[]

  @@index([role])
  @@map("guides")
}

model GuideSlide {
  id          String   @id @default(uuid())
  guideId     String   @map("guide_id")
  guide       Guide    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  order       Int      @default(0)
  title       String
  description String   @db.Text
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([guideId])
  @@map("guide_slides")
}

// ===== Event Submission (Landing Page Registration) =====

enum EventSubmissionStatus {
  PENDING
  CONTACTED
  CONFIRMED
  REJECTED
}

enum PackageTier {
  IKLAN
  BRONZE
  SILVER
  GOLD
}

model EventSubmission {
  id            String                @id @default(uuid())
  namaPanitia   String                @map("nama_panitia")
  email         String
  phone         String?
  namaEvent     String                @map("nama_event")
  lokasiEvent   String                @map("lokasi_event")
  namaInstansi  String                @map("nama_instansi")
  packageTier   PackageTier           @map("package_tier")
  status        EventSubmissionStatus @default(PENDING)
  notes         String?               @db.Text
  createdUserId String?               @map("created_user_id")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  @@index([status])
  @@index([packageTier])
  @@index([email])
  @@map("event_submissions")
}

model DailyVisitor {
  id        String   @id @default(uuid())
  date      DateTime @unique @db.Date
  count     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("daily_visitors")
}
