# Frontend Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Backend API URL - Change this to your backend server URL
VITE_API_URL=http://localhost:3001/api

# Backend Base URL - For static files (images, uploads)
VITE_BACKEND_URL=http://localhost:3001

# Alternative API URLs for different environments
# VITE_API_URL=https://api.simpaskor.com/api  # Production
# VITE_BACKEND_URL=https://api.simpaskor.com  # Production
# VITE_API_URL=https://staging-api.simpaskor.com/api  # Staging
# VITE_BACKEND_URL=https://staging-api.simpaskor.com  # Staging

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Application title and branding
VITE_APP_TITLE="Simpaskor Platform"
VITE_APP_DESCRIPTION="Platform Kompetisi Terdepan Indonesia"

# Application version (optional)
VITE_APP_VERSION="1.0.0"

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
# Token storage key (optional, defaults to 'token')
VITE_AUTH_TOKEN_KEY="token"

# User storage key (optional, defaults to 'user')
VITE_AUTH_USER_KEY="user"

# Session timeout in minutes (optional)
VITE_SESSION_TIMEOUT=1440  # 24 hours

# Google reCAPTCHA v3 Site Key
# Get from: https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY="your-recaptcha-site-key-here"

# =============================================================================
# UI/UX CONFIGURATION
# =============================================================================
# Default theme (light, dark, system)
VITE_DEFAULT_THEME="light"

# Enable dark mode toggle
VITE_ENABLE_DARK_MODE=true

# Default language (id, en)
VITE_DEFAULT_LANGUAGE="id"

# =============================================================================
# FEATURES FLAGS
# =============================================================================
# Enable/disable features for different environments
VITE_ENABLE_REGISTRATION=true
VITE_ENABLE_SOCIAL_LOGIN=false
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=false

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================
# Google Analytics (for production)
# VITE_GA_TRACKING_ID="GA-XXXXXXXXX"

# Google Maps API (for location features)
# VITE_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Firebase (for push notifications)
# VITE_FIREBASE_API_KEY="your-firebase-api-key"
# VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
# VITE_FIREBASE_PROJECT_ID="your-firebase-project"
# VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
# VITE_FIREBASE_MESSAGING_SENDER_ID="123456789"
# VITE_FIREBASE_APP_ID="1:123456789:web:abcdef123456"

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Enable debug mode (shows console logs, debug info)
VITE_DEBUG_MODE=true

# API request timeout in milliseconds
VITE_API_TIMEOUT=10000

# Enable mock data for development
VITE_ENABLE_MOCK_DATA=false

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================
# Base URL for the application (for deployment in subdirectories)
VITE_BASE_URL="/"

# Enable source maps in production (set to false for security)
VITE_GENERATE_SOURCEMAP=false

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
# Enable service worker for caching
VITE_ENABLE_SERVICE_WORKER=true

# Enable lazy loading for routes
VITE_ENABLE_LAZY_LOADING=true

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Enable HTTPS redirect in production
VITE_FORCE_HTTPS=false

# Content Security Policy (for production)
# VITE_CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-eval'"

# =============================================================================
# ERROR TRACKING (for production)
# =============================================================================
# Sentry DSN for error tracking
# VITE_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Sentry environment
# VITE_SENTRY_ENVIRONMENT="production"

# =============================================================================
# SOCIAL MEDIA & SEO
# =============================================================================
# Open Graph meta tags for social sharing
VITE_OG_TITLE="Simpaskor Platform"
VITE_OG_DESCRIPTION="Platform Kompetisi Terdepan Indonesia"
VITE_OG_IMAGE="/og-image.jpg"
VITE_OG_URL="https://simpaskor.com"

# =============================================================================
# IMPORTANT NOTES
# =============================================================================
# 1. All environment variables must start with VITE_ to be accessible in the frontend
# 2. Never put sensitive data in frontend environment variables (they are exposed to users)
# 3. Use different .env files for different environments (.env.local, .env.production)
# 4. Add .env to .gitignore to prevent committing sensitive data
#
# Environment file priority (highest to lowest):
# 1. .env.local
# 2. .env.production/.env.development (based on NODE_ENV)
# 3. .env
#
# For production deployment:
# - Set VITE_API_URL to your production backend URL
# - Disable debug mode and mock data
# - Enable appropriate analytics and error tracking
# - Configure proper CSP and security headers